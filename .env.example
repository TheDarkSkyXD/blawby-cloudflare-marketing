# Used by Wrangler CLI, maintenance scripts, and Next.js local/build-time flags.
CLOUDFLARE_ACCOUNT_ID="replace-with-account-id"
CLOUDFLARE_API_TOKEN="replace-with-api-token"
R2_CONTENT_BUCKET="replace-with-ai-search-content-bucket"
SHOW_INTERVIEWS="false"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_GA_ID="replace-with-ga-id"

# Public Worker URL used by the /help contact form. Override if your worker
# is deployed under a different subdomain than the default one in
# src/components/contact-form.tsx. Safe to leave unset in production.
NEXT_PUBLIC_WORKER_URL=""

# ────────────────────────────────────────────────────────────────────────────
# Worker secrets (NOT loaded from this file — set with `wrangler secret put`
# against wrangler.worker.toml so they live encrypted in Cloudflare):
#
#   pnpm exec wrangler secret put RESEND_API_KEY --config wrangler.worker.toml
#
# The Worker also requires SUPPORT_EMAIL, declared as a [vars] entry in
# wrangler.worker.toml (non-secret recipient address for /api/help-form).
# ────────────────────────────────────────────────────────────────────────────
